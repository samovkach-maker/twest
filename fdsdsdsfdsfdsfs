end)

-- Автостоп через 60 сек
startBtn.MouseButton1Click:Connect(function()
    if not recording then
        task.delay(60, function()
            if recording then
                stopRecording()
                startBtn.Text = "START RECORDING"
            end
        end)
    end
end)
