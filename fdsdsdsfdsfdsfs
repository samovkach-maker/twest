-- функции записи
local function startRecording()
    recordedCalls = {}
    recording = true
    outputText.Text = "Запись началась! Ищи игрока с bounty и убей его.\nЗапись остановится автоматически через 60 сек."
    
    local mt = getrawmetatable(game)
    oldNamecall = mt.__namecall
    setreadonly(mt, false)
    mt.__namecall = function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        if method == "FireServer" and recording then
            local path = "?"
            pcall(function() path = self:GetFullName() end)
            table.insert(recordedCalls, {
                time = tick(),
                remote = path,
                args = { ... }
            })
            -- Обновим GUI
            local lines = {}
            for i = #recordedCalls, math.max(1, #recordedCalls-4), -1 do
                local call = recordedCalls[i]
                lines[#lines+1] = string.format("[%d] %s", i, call.remote)
            end
            outputText.Text = "Запись активна (" .. #recordedCalls .. " вызовов)\n\nПоследние:\n" .. table.concat(lines, "\n")
        end
        return oldNamecall(self, ...)
    end
    setreadonly(mt, true)
end

local function stopRecording()
    if not recording then return end
    recording = false
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    mt.__namecall = oldNamecall
    setreadonly(mt, true)
    
    local text = "=== ЗАПИСАННЫЕ FIRESERVER (" .. #recordedCalls .. " вызовов) ===\n\n"
    for i, call in ipairs(recordedCalls) do
        text = text .. string.format("[%d] %s\n", i, call.remote)
        for j, arg in ipairs(call.args) do
            local val = tostring(arg)
            if #val > 60 then val = val:sub(1,60).."..." end
            text = text .. string.format("   Arg%d: %s (%s)\n", j, val, typeof(arg))
        end
    end
    
    outputText.Text = text
    setclipboard(text)
end

startBtn.MouseButton1Click:Connect(function()
    if recording then
        stopRecording()
        startBtn.Text = "START RECORDING"
    else
        startRecording()
        startBtn.Text = "STOP RECORDING"
    end
end)

copyBtn.MouseButton1Click:Connect(function()
